{
  "manifest_version": 3,
  "name": "Start - A Clean New Tab",
  "short_name": "Start",
  "description": "A clean, simple, new tab browser extension that supports local image backgrounds",
  "version": "0.0.3",
  "homepage_url": "https://github.com/ChangJun2019/start-new-tab",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
